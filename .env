# ─── Copia este archivo como .env ────────────────────────────────────────────
# cp .env.example .env

# URL del servidor Ollama (por defecto: local)
OLLAMA_HOST=http://localhost:11434

# Modelo a usar. Opciones recomendadas para Apple M5 (16GB):
#   llama3:8b       → mejor balance velocidad/precisión (~4s por inferencia en M5)
#   llama3:8b-q4_0  → cuantizado 4-bit, más rápido (~2s), ligera pérdida de calidad
#   mistral:7b      → alternativa con buen razonamiento estructurado
#   phi3:mini       → ultra-rápido para pruebas (~1s), menor precisión
OLLAMA_MODEL=llama3:8b
