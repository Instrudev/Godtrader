# Credenciales y datos sensibles
.claude/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Modelos entrenados (se regeneran con train_model.py)
models/*.pkl
models/versions/

# Runtime database (not versioned — init_db creates on first run)
*.db
*.db-journal
*.db-shm
*.db-wal
*.db.backup*
*.sqlite
*.sqlite3

# Local database archives (historical, not committed)
archive/databases/

# Datos temporales
trades_history.json
.pytest_cache/

# Runtime logs (generados por tests y ejecución)
logs/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
